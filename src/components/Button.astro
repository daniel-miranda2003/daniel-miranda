---
interface Props {
  href?: string;
  variant?: 'primary' | 'secondary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  class?: string;
}

const { 
  href, 
  variant = 'primary', 
  size = 'md',
  class: className = '' 
} = Astro.props;

const baseClasses = 'button-base inline-flex items-center justify-center font-semibold rounded-xl cursor-pointer';

const sizeClasses = {
  sm: 'py-2 px-4 text-sm',
  md: 'py-3 px-6 text-base',
  lg: 'py-4 px-8 text-lg',
};

const variantStyles = {
  primary: {
    background: 'linear-gradient(135deg, #0284c7, #38bdf8)',
    color: 'white',
  },
  secondary: {
    background: 'linear-gradient(135deg, #E63946, #FF6B6B)',
    color: 'white',
  },
  outline: {
    background: 'transparent',
    border: '2px solid #0284c7',
    color: '#0284c7',
  },
};

const classes = `${baseClasses} button-${variant} ${sizeClasses[size]} ${className}`;
const Tag = href ? 'a' : 'button';
---

<Tag href={href} class={classes} style={variantStyles[variant]}>
  <slot />
</Tag>

<style>
  .button-base {
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
  }

  .button-base::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: rgba(255, 255, 255, 0.2);
    transition: left 0.5s ease;
    z-index: 1;
  }

  .button-base:hover::before {
    left: 100%;
  }

  .button-primary,
  .button-secondary {
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
  }

  .button-primary:hover,
  .button-secondary:hover {
    transform: translateY(-2px);
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.2);
  }

  .button-primary:active,
  .button-secondary:active {
    transform: translateY(0);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
  }

  .button-outline {
    box-shadow: none;
  }

  .button-outline:hover {
    background: var(--color-primary-dark);
    color: white;
    transform: translateY(-2px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
  }

  .button-outline:active {
    transform: translateY(0);
    box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05);
  }
</style>