---
import { useTranslations } from '@/i18n/utils';
import type { Language } from '@/config/i18n';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="contacto">
  <div class="max-w-4xl mx-auto text-center">
    <h2 class="text-4xl md:text-5xl font-bold mb-4 text-foreground">
      {t('contact.title')}
    </h2>
    
    <p class="text-lg text-secondary-600 dark:text-secondary-400 mb-4">
      {t('contact.subtitle')}
    </p>
    
    <p class="text-secondary-700 dark:text-secondary-300 mb-12">
      {t('contact.description')}
    </p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
      <!-- Email -->
      <div class="p-8 md:p-12 bg-background rounded-2xl border border-slate-200 dark:border-slate-700/30 hover:shadow-xl transition-shadow duration-300">
        <p class="text-sm font-semibold text-secondary-600 dark:text-secondary-400 mb-4 uppercase tracking-wide">
          {lang === 'es' ? 'Correo Electrónico' : 'Email'}
        </p>
        <a 
          href="mailto:danielmiranda18lapaz@gmail.com"
          class="text-base md:text-lg font-bold text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors hover:underline"
          aria-label={lang === 'es' ? 'Enviar correo a danielmiranda18lapaz@gmail.com' : 'Send email to danielmiranda18lapaz@gmail.com'}
        >
          danielmiranda18lapaz@gmail.com
        </a>
        <p class="text-xs text-secondary-500 mt-2">
          danielmiranda18lapaz
        </p>
      </div>
      
      <div class="p-8 md:p-12 bg-background rounded-2xl border border-slate-200 dark:border-slate-700/30 hover:shadow-xl transition-shadow duration-300">
        <p class="text-sm font-semibold text-secondary-600 dark:text-secondary-400 mb-4 uppercase tracking-wide">
          {lang === 'es' ? 'Teléfono' : 'Phone'}
        </p>
        <a 
          href="https://wa.me/59175875587"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center justify-center gap-3 text-lg md:text-xl font-bold text-primary-600 dark:text-primary-400 hover:text-primary-700 dark:hover:text-primary-300 transition-colors hover:underline"
          aria-label={lang === 'es' ? 'Contactar por WhatsApp al +591 75875587' : 'Contact via WhatsApp at +591 75875587'}
        >
          <svg 
            class="w-8 h-6 rounded" 
            viewBox="0 0 900 600" 
            xmlns="http://www.w3.org/2000/svg"
            role="img"
            aria-label="Bandera de Bolivia"
          >
            <title>Bandera de Bolivia</title>
            <rect width="900" height="200" fill="#CE1126"/>
            <rect y="200" width="900" height="200" fill="#FFCD00"/>
            <rect y="400" width="900" height="200" fill="#007A5E"/>
          </svg>
          <span>(+591) 75875587</span>
        </a>
        <p class="text-xs text-secondary-500 dark:text-secondary-500 mt-2">
          {lang === 'es' ? 'Enviar por WhatsApp' : 'Send via WhatsApp'}
        </p>
      </div>
    </div>
    
    <div>
      <p class="text-sm font-semibold text-secondary-600 dark:text-secondary-400 mb-8 uppercase tracking-wide">
        {lang === 'es' ? 'Sígueme en' : 'Follow me on'}
      </p>
      
      <div class="flex justify-center gap-6 flex-wrap">
        <a 
          href="https://github.com/daniel-miranda18" 
          target="_blank"
          rel="noopener noreferrer"
          class="group p-5 rounded-full bg-background border border-slate-200 dark:border-slate-700/30 hover:shadow-xl transition-all duration-300 hover:scale-110"
          aria-label="GitHub"
        >
          <svg class="w-7 h-7 text-foreground transition-colors group-hover:text-primary-600 dark:group-hover:text-primary-400" fill="currentColor" viewBox="0 0 24 24" role="img" aria-hidden="true">
            <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
          </svg>
        </a>
        
        <a 
          href="https://bo.linkedin.com/in/luis-daniel-miranda-machaca-b7a033222" 
          target="_blank"
          rel="noopener noreferrer"
          class="group p-5 rounded-full bg-background border border-slate-200 dark:border-slate-700/30 hover:shadow-xl transition-all duration-300 hover:scale-110"
          aria-label="LinkedIn"
        >
          <svg class="w-7 h-7 text-foreground transition-colors group-hover:text-primary-600 dark:group-hover:text-primary-400" fill="currentColor" viewBox="0 0 24 24" role="img" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>