---
import Button from '@/components/Button.astro';
import { useTranslations } from '@/i18n/utils';
import type { Language } from '@/config/i18n';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="text-center px-2">
  <p class="text-primary-600 dark:text-primary-400 font-medium mb-4 text-lg animate-fade-in">
    {t('hero.greeting')}
  </p>

  <div class="mb-6">
    <h2 class="text-5xl md:text-7xl font-bold text-primary-900 dark:text-primary-100">
      <span id="typing-name" class="text-primary-900 dark:text-primary-100"></span>
      <span
        id="typing-role"
        class="typing-role text-secondary-600 dark:text-secondary-400"
        data-role={t('hero.subtitle')}
      ></span>
      <span class="typing-cursor">|</span>
    </h2>
  </div>

  <p class="text-lg text-secondary-700 dark:text-secondary-300 mb-12 max-w-2xl mx-auto leading-relaxed animate-fade-in-delay-2">
    {t('hero.description')}
  </p>

  <div class="flex gap-4 justify-center flex-wrap animate-fade-in-delay-3">
    <a href="#proyectos" class="hero-scroll-link">
      <Button variant="primary" size="lg">
        {t('hero.cta')}
      </Button>
    </a>
    <a href="#contacto" class="hero-scroll-link">
      <Button variant="outline" size="lg">
        {t('hero.contact')}
      </Button>
    </a>
  </div>
</section>

<script>
  let heroRunId = 0;
  const pendingTimeouts: ReturnType<typeof setTimeout>[] = [];
  let scrollAbort: AbortController | null = null;

  function clearHeroTimers() {
    while (pendingTimeouts.length) {
      const id = pendingTimeouts.pop();
      if (id !== undefined) clearTimeout(id);
    }
  }

  function schedule(ms: number, fn: () => void, run: number) {
    const id = setTimeout(() => {
      if (run !== heroRunId) return;
      fn();
    }, ms);
    pendingTimeouts.push(id);
  }

  function initHeroTyping() {
    heroRunId++;
    const run = heroRunId;
    clearHeroTimers();

    const nameElement = document.getElementById('typing-name');
    const roleElement = document.getElementById('typing-role');
    const cursor = document.querySelector('.typing-cursor');

    if (!nameElement || !roleElement) return;

    nameElement.textContent = '';
    roleElement.textContent = '';
    roleElement.classList.remove('is-visible');
    cursor?.classList.remove('cursor-stop');

    const name = 'Daniel Miranda';
    const role = roleElement.getAttribute('data-role') || '';

    let nameIndex = 0;
    let roleIndex = 0;

    function typeName() {
      if (run !== heroRunId) return;
      if (nameIndex < name.length) {
        nameElement.textContent += name.charAt(nameIndex);
        nameIndex++;
        schedule(Math.random() * 100 + 80, typeName, run);
        return;
      }
      roleElement.classList.add('is-visible');
      schedule(200, typeRole, run);
    }

    function typeRole() {
      if (run !== heroRunId) return;
      if (roleIndex < role.length) {
        roleElement.textContent += role.charAt(roleIndex);
        roleIndex++;
        schedule(Math.random() * 50 + 45, typeRole, run);
      } else {
        schedule(500, () => {
          if (run !== heroRunId) return;
          cursor?.classList.add('cursor-stop');
        }, run);
      }
    }

    schedule(400, typeName, run);
  }

  function initHeroScroll() {
    scrollAbort?.abort();
    scrollAbort = new AbortController();
    const signal = scrollAbort.signal;

    document.querySelectorAll('.hero-scroll-link').forEach((link) => {
      link.addEventListener(
        'click',
        (e) => {
          e.preventDefault();
          const href = link.getAttribute('href')?.substring(1);
          const target = document.getElementById(href || '');
          if (target) {
            const headerOffset = 100;
            const top = target.getBoundingClientRect().top + window.pageYOffset - headerOffset;
            window.scrollTo({ top, behavior: 'smooth' });
          }
        },
        { signal }
      );
    });
  }

  function initHero() {
    initHeroTyping();
    initHeroScroll();
  }

  document.addEventListener('astro:page-load', initHero);
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes blink {
    0%,
    49% {
      opacity: 1;
    }
    50%,
    100% {
      opacity: 0;
    }
  }

  .animate-fade-in {
    animation: fadeIn 0.8s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
    opacity: 0;
  }

  .animate-fade-in-delay-2 {
    animation: fadeIn 0.8s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
    animation-delay: 2.8s;
    opacity: 0;
  }

  .animate-fade-in-delay-3 {
    animation: fadeIn 0.8s cubic-bezier(0.22, 0.61, 0.36, 1) forwards;
    animation-delay: 3.3s;
    opacity: 0;
  }

  .typing-cursor {
    animation: blink 1s step-end infinite;
    color: currentColor;
    font-weight: 100;
  }

  .typing-cursor.cursor-stop {
    animation: none;
    opacity: 0;
  }

  h2 {
    line-height: 1.2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 0.4rem;
  }

  .typing-role {
    min-height: 1.2em;
    font-size: 0.42em;
    font-weight: 600;
    opacity: 0;
  }

  .typing-role.is-visible {
    opacity: 1;
  }

  @media (max-width: 768px) {
    h2 {
      font-size: 2rem;
      gap: 0.15rem;
    }
  }
</style>
