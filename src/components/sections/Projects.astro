---
import { useTranslations } from '@/i18n/utils';
import type { Language } from '@/config/i18n';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const projects = [
  {
    id: 1,
    titleEs: 'App Permisos de Viaje',
    titleEn: 'Travel Permits App',
    descEs: 'Aplicación móvil para Android e iOS desarrollada con Flutter y arquitectura Clean.',
    descEn: 'Mobile application for Android and iOS developed with Flutter and Clean architecture.',
    tags: ['Flutter', 'Dart'],
    link: 'https://apps.apple.com/bo/app/permisos-de-viaje/id6756247460',
    year: '2023'
  },
  {
    id: 2,
    titleEs: 'Sistema de Control de Aportes',
    titleEn: 'Contribution Control System',
    descEs: 'Sistema web para gestión de pagos y control de afiliados con reportes administrativos.',
    descEn: 'Web system for payment management and affiliate control with administrative reports.',
    tags: ['PHP', 'Bootstrap 5', 'MySQL'],
    link: 'https://app.colbiofarlp.com/',
    year: '2023 - 2024'
  },
  {
    id: 3,
    titleEs: 'Sitio Web ONG Crea Bolivia',
    titleEn: 'Crea Bolivia NGO Website',
    descEs: 'Implementación de sitio web en WordPress con configuración de servidor y optimización.',
    descEn: 'WordPress website implementation with server configuration and optimization.',
    tags: ['WordPress', 'PHP'],
    link: 'https://www.creabolivia.org.bo/',
    year: '2025'
  },
];
---

<section id="proyectos" class="relative py-16 md:py-20 overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-40 left-1/4 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-40 right-1/4 w-96 h-96 bg-primary-600/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-4xl mx-auto px-6 lg:px-8">
    <h2 class="text-4xl md:text-5xl font-bold mb-4 text-foreground text-center">
      {t('projects.title')}
    </h2>
    
    <p class="text-lg text-muted-foreground text-center mb-16 max-w-2xl mx-auto">
      {t('projects.subtitle')}
    </p>
    
    <div class="space-y-12">
      {projects.map((project) => (
        <div class="space-y-3">
          <time class="text-sm font-medium text-muted-foreground">
            {project.year}
          </time>
          
          <h3 class="text-xl font-semibold text-foreground">
            {lang === 'es' ? project.titleEs : project.titleEn}
          </h3>
          
          <p class="text-base text-muted-foreground leading-relaxed">
            {lang === 'es' ? project.descEs : project.descEn}
          </p>
          
          <div class="flex flex-wrap gap-2">
            {project.tags.map(tag => (
              <span class="text-xs px-2.5 py-1 rounded-md bg-primary-50 dark:bg-primary-950/50 border border-primary-200 dark:border-primary-800 text-primary-700 dark:text-primary-300 font-medium">
                {tag}
              </span>
            ))}
          </div>
          
          <div class="pt-1">
            <a 
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center text-foreground bg-primary-600 dark:bg-primary-500 hover:bg-primary-700 dark:hover:bg-primary-600 border border-primary-700 dark:border-primary-400 focus:ring-4 focus:ring-primary-500/20 font-medium rounded-lg text-sm px-4 py-2 focus:outline-none transition-colors"
            >
              {t('projects.viewProject')}
              <svg class="w-3.5 h-3.5 ms-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>