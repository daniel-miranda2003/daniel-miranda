---
import { useTranslations } from '@/i18n/utils';
import type { Language } from '@/config/i18n';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const projects = [
  {
    id: 1,
    titleEs: 'Colegio de Bioquímica y Farmacia de La Paz',
    titleEn: 'College of Biochemistry and Pharmacy of La Paz',
    roleEs: 'Desarrollo web',
    roleEn: 'Web development',
    periodEs: '2023 — presente',
    periodEn: '2023 — present',
    descEs:
      'Sistema web para gestionar pagos y cuotas de afiliados del colegio profesional, reemplazando procesos manuales por flujos automatizados.',
    descEn:
      'Web system to manage payments and membership dues for the professional association, replacing manual work with automated workflows.',
    link: 'https://app.colbiofarlp.com/',
    githubUrl: undefined,
    highlightsEs: [
      'Registro de pagos y cálculo de deudas sistematizados',
      'Reportes administrativos de pagos e historial de afiliados',
      'Alertas para afiliados con deudas y seguimiento de cobranza',
    ],
    highlightsEn: [
      'Streamlined payment logging and debt calculation',
      'Admin reporting on payments and member history',
      'Alerts for overdue accounts to support collections',
    ],
  },
  {
    id: 2,
    titleEs: 'ONG Crea Bolivia',
    titleEn: 'Crea Bolivia NGO',
    roleEs: 'Desarrollador web',
    roleEn: 'Web developer',
    periodEs: 'Oct 2025 — presente',
    periodEn: 'Oct 2025 — present',
    descEs:
      'Lanzamiento y operación del sitio institucional de la organización sin fines de lucro.',
    descEn:
      'Launch and ongoing operation of the nonprofit’s institutional website.',
    link: 'https://www.creabolivia.org.bo/',
    githubUrl: undefined,
    highlightsEs: [
      'Desarrollo integral del sitio',
      'Servidor, dominio y hardening de seguridad',
      'Diseño y arquitectura de contenidos a medida',
      'Mantenimiento continuo en producción',
    ],
    highlightsEn: [
      'End-to-end site build',
      'Server, domain, and security hardening',
      'Custom layout and content structure',
      'Ongoing production maintenance',
    ],
  },
  {
    id: 3,
    titleEs: 'Gobierno Autónomo Municipal de La Paz',
    titleEn: 'Autonomous Municipal Government of La Paz',
    roleEs: 'Desarrollador móvil · pasantía',
    roleEn: 'Mobile developer · internship',
    periodEs: 'Jul 2025 — dic 2025',
    periodEn: 'Jul 2025 — Dec 2025',
    descEs:
      'Participación en apps móviles para Android e iOS orientadas a trámites y servicios ciudadanos.',
    descEn:
      'Contributed to Android and iOS apps for municipal services and citizen-facing workflows.',
    link: undefined,
    githubUrl: undefined,
    highlightsEs: [
      'App «Permisos de viaje»: solicitudes para menores, biometría y seguimiento de trámites',
      'App «iGOB+»: integración de múltiples servicios del gobierno municipal en una sola experiencia',
    ],
    highlightsEn: [
      'Travel Permits app: minor travel requests, biometric sign-in, and application tracking',
      'iGOB+ app: integrated multiple municipal services into the primary citizen app',
    ],
  },
];
---

<section id="proyectos" class="relative py-16 md:py-20 overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-40 left-1/4 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-40 right-1/4 w-96 h-96 bg-primary-600/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-4xl mx-auto px-6 lg:px-8">
    <h2 class="text-4xl md:text-5xl font-bold mb-4 text-foreground text-center">
      {t('projects.title')}
    </h2>

    <p class="text-lg text-muted-foreground text-center mb-14 max-w-2xl mx-auto">
      {t('projects.subtitle')}
    </p>

    <div class="space-y-10">
      {projects.map((project) => (
        <article class="relative rounded-2xl border border-border/90 bg-linear-to-b from-muted/25 to-background p-6 md:p-8 shadow-sm hover:border-primary-500/25 hover:shadow-md transition-all duration-300">
          <div class="flex flex-col sm:flex-row sm:items-baseline sm:justify-between gap-1 sm:gap-4 mb-3">
            <p class="text-xs font-semibold uppercase tracking-wider text-primary-600 dark:text-primary-400">
              {lang === 'es' ? project.roleEs : project.roleEn}
            </p>
            <time class="text-sm font-medium text-muted-foreground tabular-nums shrink-0">
              {lang === 'es' ? project.periodEs : project.periodEn}
            </time>
          </div>

          <h3 class="text-xl font-semibold text-foreground mb-3">
            {lang === 'es' ? project.titleEs : project.titleEn}
          </h3>

          <p class="text-base text-muted-foreground leading-relaxed mb-4">
            {lang === 'es' ? project.descEs : project.descEn}
          </p>

          <ul class="space-y-2 text-sm text-secondary-700 dark:text-secondary-300 mb-5">
            {(lang === 'es' ? project.highlightsEs : project.highlightsEn).map((highlight) => (
              <li class="flex items-start gap-2.5">
                <span class="mt-1.5 h-1 w-1 shrink-0 rounded-full bg-primary-500"></span>
                <span>{highlight}</span>
              </li>
            ))}
          </ul>

          {(project.link || project.githubUrl) && (
            <div class="flex items-center gap-3 flex-wrap">
              {project.link && (
                <a
                  href={project.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center text-foreground bg-primary-600 dark:bg-primary-500 hover:bg-primary-700 dark:hover:bg-primary-600 border border-primary-700 dark:border-primary-400 focus:ring-4 focus:ring-primary-500/20 font-medium rounded-lg text-sm px-4 py-2 focus:outline-none transition-colors"
                >
                  {t('projects.viewProject')}
                  <svg class="w-3.5 h-3.5 ms-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
                  </svg>
                </a>
              )}
              {project.githubUrl && (
                <a
                  href={project.githubUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center text-foreground bg-transparent hover:bg-secondary-100 dark:hover:bg-secondary-800 border border-border focus:ring-4 focus:ring-primary-500/20 font-medium rounded-lg text-sm px-4 py-2 focus:outline-none transition-colors"
                >
                  {t('projects.viewCode')}
                  <svg class="w-4 h-4 ms-2" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.24c-3.34.73-4.04-1.42-4.04-1.42-.54-1.39-1.33-1.76-1.33-1.76-1.09-.75.08-.74.08-.74 1.2.09 1.83 1.24 1.83 1.24 1.08 1.86 2.83 1.33 3.51 1.02.11-.78.42-1.33.76-1.63-2.67-.31-5.47-1.34-5.47-5.94 0-1.31.47-2.37 1.24-3.2-.12-.31-.54-1.55.12-3.23 0 0 1.01-.32 3.3 1.22a11.45 11.45 0 0 1 6 0c2.29-1.54 3.3-1.22 3.3-1.22.66 1.68.24 2.92.12 3.23.77.83 1.24 1.89 1.24 3.2 0 4.61-2.81 5.62-5.49 5.93.43.37.82 1.1.82 2.22v3.3c0 .32.22.7.83.58A12 12 0 0 0 12 .5z" />
                  </svg>
                </a>
              )}
            </div>
          )}
        </article>
      ))}
    </div>
  </div>
</section>
