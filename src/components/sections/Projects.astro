---
import { useTranslations } from '@/i18n/utils';
import type { Language } from '@/config/i18n';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const projects = [
  {
    id: 1,
    titleEs: 'App Permisos de Viaje',
    titleEn: 'Travel Permits App',
    descEs: 'Aplicación móvil para Android e iOS desarrollada con Flutter y arquitectura Clean.',
    descEn: 'Mobile application for Android and iOS developed with Flutter and Clean architecture.',
    tags: ['Flutter', 'Dart'],
    link: 'https://apps.apple.com/bo/app/permisos-de-viaje/id6756247460',
    githubUrl: undefined,
    highlightsEs: [
      'Arquitectura Clean con BLoC pattern',
      'Publicada en App Store y Google Play',
      'Integración con APIs REST gubernamentales'
    ],
    highlightsEn: [
      'Clean architecture with BLoC pattern',
      'Published on App Store and Google Play',
      'Integration with government REST APIs'
    ],
    year: '2023'
  },
  {
    id: 2,
    titleEs: 'Sistema de Control de Aportes',
    titleEn: 'Contribution Control System',
    descEs: 'Sistema web para gestión de pagos y control de afiliados con reportes administrativos.',
    descEn: 'Web system for payment management and affiliate control with administrative reports.',
    tags: ['PHP', 'MySQL'],
    link: 'https://app.colbiofarlp.com/',
    githubUrl: undefined,
    highlightsEs: [
      'Gestión de +500 afiliados',
      'Módulo de reportes PDF automatizados',
      'Panel administrativo con roles y permisos'
    ],
    highlightsEn: [
      'Management for 500+ members',
      'Automated PDF reporting module',
      'Admin panel with roles and permissions'
    ],
    year: '2023 - 2024'
  },
  {
    id: 3,
    titleEs: 'Sitio Web ONG Crea Bolivia',
    titleEn: 'Crea Bolivia NGO Website',
    descEs: 'Implementación de sitio web en WordPress con configuración de servidor y optimización.',
    descEn: 'WordPress website implementation with server configuration and optimization.',
    tags: ['WordPress', 'PHP'],
    link: 'https://www.creabolivia.org.bo/',
    githubUrl: undefined,
    highlightsEs: [
      'Optimización SEO con Core Web Vitals en verde',
      'Configuración de servidor Linux + Nginx',
      'Integración con formularios y donaciones'
    ],
    highlightsEn: [
      'SEO optimization with green Core Web Vitals',
      'Linux + Nginx server configuration',
      'Forms and donations integration'
    ],
    year: '2025'
  },
];
---

<section id="proyectos" class="relative py-16 md:py-20 overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-40 left-1/4 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-40 right-1/4 w-96 h-96 bg-primary-600/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-4xl mx-auto px-6 lg:px-8">
    <h2 class="text-4xl md:text-5xl font-bold mb-4 text-foreground text-center">
      {t('projects.title')}
    </h2>
    
    <p class="text-lg text-muted-foreground text-center mb-16 max-w-2xl mx-auto">
      {t('projects.subtitle')}
    </p>
    
    <div class="space-y-12">
      {projects.map((project) => (
        <div class="space-y-3">
          <time class="text-sm font-medium text-muted-foreground">
            {project.year}
          </time>
          
          <h3 class="text-xl font-semibold text-foreground">
            {lang === 'es' ? project.titleEs : project.titleEn}
          </h3>
          
          <p class="text-base text-muted-foreground leading-relaxed">
            {lang === 'es' ? project.descEs : project.descEn}
          </p>

          <ul class="space-y-1.5 text-sm text-secondary-700 dark:text-secondary-300">
            {(lang === 'es' ? project.highlightsEs : project.highlightsEn).map((highlight) => (
              <li class="flex items-start gap-2">
                <span class="text-primary-600 dark:text-primary-400 mt-0.5">•</span>
                <span>{highlight}</span>
              </li>
            ))}
          </ul>
          
          <div class="pt-1 flex items-center gap-3 flex-wrap">
            <a 
              href={project.link}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center text-foreground bg-primary-600 dark:bg-primary-500 hover:bg-primary-700 dark:hover:bg-primary-600 border border-primary-700 dark:border-primary-400 focus:ring-4 focus:ring-primary-500/20 font-medium rounded-lg text-sm px-4 py-2 focus:outline-none transition-colors"
            >
              {t('projects.viewProject')}
              <svg class="w-3.5 h-3.5 ms-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
              </svg>
            </a>
            {project.githubUrl && (
              <a
                href={project.githubUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center text-foreground bg-transparent hover:bg-secondary-100 dark:hover:bg-secondary-800 border border-border focus:ring-4 focus:ring-primary-500/20 font-medium rounded-lg text-sm px-4 py-2 focus:outline-none transition-colors"
              >
                {t('projects.viewCode')}
                <svg class="w-4 h-4 ms-2" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 .5a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.24c-3.34.73-4.04-1.42-4.04-1.42-.54-1.39-1.33-1.76-1.33-1.76-1.09-.75.08-.74.08-.74 1.2.09 1.83 1.24 1.83 1.24 1.08 1.86 2.83 1.33 3.51 1.02.11-.78.42-1.33.76-1.63-2.67-.31-5.47-1.34-5.47-5.94 0-1.31.47-2.37 1.24-3.2-.12-.31-.54-1.55.12-3.23 0 0 1.01-.32 3.3 1.22a11.45 11.45 0 0 1 6 0c2.29-1.54 3.3-1.22 3.3-1.22.66 1.68.24 2.92.12 3.23.77.83 1.24 1.89 1.24 3.2 0 4.61-2.81 5.62-5.49 5.93.43.37.82 1.1.82 2.22v3.3c0 .32.22.7.83.58A12 12 0 0 0 12 .5z"></path>
                </svg>
              </a>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>