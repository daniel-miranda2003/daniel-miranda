---
import { useTranslations } from '@/i18n/utils';
import type { Language } from '@/config/i18n';
import { Image } from 'astro:assets';
import selfie from '@/assets/selfie.png';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const pillars = [
  { key: 'about.pillar1', icon: 'M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z' },
  { key: 'about.pillar2', icon: 'M5 12h14M5 12a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v4a2 2 0 01-2 2M5 12a2 2 0 00-2 2v4a2 2 0 002 2h14a2 2 0 002-2v-4a2 2 0 00-2-2m-2-4h.01M17 16h.01' },
  { key: 'about.pillar3', icon: 'M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4' },
] as const;

const cardBase =
  'rounded-2xl border border-border bg-linear-to-b from-muted/50 to-background p-4 sm:p-5 shadow-sm hover:border-primary-500/25 hover:shadow-md transition-all duration-300';
---

<section id="sobre-mi" class="relative py-16 md:py-24 overflow-hidden">
  <div class="absolute inset-0 -z-10 pointer-events-none">
    <div class="absolute top-20 right-[-10%] w-[min(100%,380px)] aspect-square bg-primary-500/[0.06] rounded-full blur-3xl motion-safe:animate-pulse motion-safe:duration-[6s]"></div>
    <div class="absolute bottom-10 left-[-8%] w-[min(100%,320px)] aspect-square bg-sky-500/[0.05] rounded-full blur-3xl motion-safe:animate-pulse motion-safe:duration-[7s]"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <div class="text-center mb-12 md:mb-14">
      <h2 class="text-4xl md:text-5xl font-black tracking-tight text-foreground mb-3">
        {t('about.title')}
      </h2>
      <p class="text-sm md:text-base font-medium text-primary-600 dark:text-primary-400 uppercase tracking-[0.2em]">
        {t('about.subtitle')}
      </p>
    </div>

    <div class="grid lg:grid-cols-12 gap-6 lg:gap-8 lg:items-stretch">
      <div class="lg:col-span-5 flex justify-center lg:justify-end lg:pt-1">
        <div class="w-full max-w-[380px]">
          <div class="rounded-2xl overflow-hidden aspect-square shadow-lg ring-1 ring-border bg-muted/20">
            <Image
              src={selfie}
              alt={t('about.photoAlt')}
              width={320}
              height={320}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>

      <div class:list={['lg:col-span-7 flex flex-col gap-6 lg:gap-8', 'min-h-0']}>
        <div class:list={[cardBase, 'p-5 sm:p-6']}>
          <p class="text-lg md:text-xl font-semibold text-foreground leading-snug tracking-tight">
            {t('about.intro')}
          </p>
        </div>

        <div class="grid gap-3 sm:grid-cols-3 sm:items-stretch flex-1">
          {pillars.map((pillar) => (
            <div class:list={['group flex flex-col', cardBase, 'motion-safe:hover:-translate-y-0.5']}>
              <div class="mb-3 inline-flex rounded-xl bg-primary-500/10 p-2 ring-1 ring-primary-500/15 w-fit">
                <svg class="w-4 h-4 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={pillar.icon} />
                </svg>
              </div>
              <p class="text-xs md:text-sm text-muted-foreground leading-relaxed flex-1">
                {t(pillar.key)}
              </p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
