---
import { useTranslations } from '@/i18n/utils';
import type { Language } from '@/config/i18n';
import { Image } from 'astro:assets';
import selfie from '@/assets/selfie.png';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="sobre-mi" class="relative py-16 md:py-20 overflow-hidden">
  <div class="absolute inset-0 -z-10">
    <div class="absolute top-20 right-0 w-72 h-72 bg-primary-500/5 rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 left-0 w-72 h-72 bg-primary-600/5 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-6xl mx-auto px-6 lg:px-8">
    <h2 class="text-4xl md:text-5xl font-bold mb-4 text-foreground text-center">
      {t('about.title')}
    </h2>
    
    <p class="text-lg text-foreground text-center mb-12 max-w-2xl mx-auto">
      {t('about.subtitle')}
    </p>

    <div class="flex flex-col items-center mb-8">
      <div class="relative group w-48 h-48 md:w-56 md:h-56">
        <div class="absolute -inset-1 from-primary-600 to-primary-400 rounded-full blur-xl opacity-20 group-hover:opacity-25 transition-opacity duration-500"></div>
        <div class="relative w-full h-full from-background to-muted rounded-full p-1 shadow-xl">
          <div class="w-full h-full rounded-full overflow-hidden from-primary-50 to-primary-100 dark:from-primary-950 dark:to-primary-900">
            <Image 
              src={selfie} 
              alt={t('about.photoAlt') || 'Foto de perfil de Daniel Miranda'}
              width={224}
              height={224}
              class="w-full h-full object-cover"
            />
          </div>
        </div>
      </div>
    </div>

    <div class="max-w-3xl mx-auto">
      <div class="space-y-5">
        
        <div>
          <p class="text-sm md:text-base leading-relaxed text-muted-foreground">
            {t('about.intro')}
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-3 pt-1">
          
          <div class="group relative bg-linear-to-br from-background to-muted/30 border border-border rounded-lg p-4 hover:border-primary-500/40 transition-all duration-300">
            <div class="flex items-start gap-3">
              <div class="shrink-0 w-9 h-9 rounded-lg bg-primary-500/10 flex items-center justify-center ring-1 ring-primary-500/20 group-hover:ring-primary-500/30 transition-all">
                <svg class="w-4 h-4 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-foreground leading-relaxed">
                  {t('about.specialty')}
                </p>
              </div>
            </div>
          </div>

          <div class="group relative bg-linear-to-br from-background to-muted/30 border border-border rounded-lg p-4 hover:border-primary-500/40 transition-all duration-300">
            <div class="flex items-start gap-3">
              <div class="shrink-0 w-9 h-9 rounded-lg bg-primary-500/10 flex items-center justify-center ring-1 ring-primary-500/20 group-hover:ring-primary-500/30 transition-all">
                <svg class="w-4 h-4 text-primary-600 dark:text-primary-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/>
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm font-medium text-foreground leading-relaxed">
                  {t('about.fullstack')}
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>