---
import { useTranslations } from '@/i18n/utils';
import type { Language } from '@/config/i18n';
import { Image } from 'astro:assets';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="expertise">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-5xl md:text-6xl font-black mb-6 text-foreground">
        {t('expertise.title')}
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      <div class="md:col-span-2 group">
        <div class="relative bg-linear-to-br from-background to-muted dark:from-background dark:to-secondary-950/50 border border-primary-300/60 dark:border-primary-800/40 rounded-3xl p-10 hover:shadow-2xl transition-all duration-300 h-full overflow-hidden">
          <div class="absolute top-0 right-0 w-96 h-96 bg-primary-500/5 rounded-full blur-3xl -z-10"></div>
          <div class="relative z-10">
            <div class="flex items-start gap-6 mb-8">
              <div class="inline-flex p-4 rounded-2xl bg-primary-100 dark:bg-primary-900/30 shrink-0 group-hover:scale-110 transition-transform duration-300">
                <Image 
                  src="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/icons/flutter/flutter-original.svg" 
                  alt="Flutter logo" 
                  width={32}
                  height={32}
                  class="w-8 h-8"
                  loading="lazy"
                />
              </div>
              <div>
                <h3 class="text-4xl md:text-5xl font-black text-primary-600 dark:text-primary-400 mb-2">
                  {t('expertise.flutter')}
                </h3>
                <p class="text-lg text-foreground font-semibold">
                  {t('expertise.mainSpecialty')}
                </p>
              </div>
            </div>

            <p class="text-lg leading-relaxed text-foreground mb-8">
              {t('expertise.flutterDescription')}
            </p>

            <div class="space-y-3">
              <h4 class="text-sm font-bold uppercase tracking-widest text-secondary-600 dark:text-secondary-400">
                {t('expertise.solutions')}
              </h4>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {[
                  t('expertise.solution1'),
                  t('expertise.solution2'),
                  t('expertise.solution3'),
                ].map((solution) => (
                  <div class="flex items-center gap-3 p-3 rounded-lg bg-primary-50 dark:bg-primary-900/20 border border-primary-200/50 dark:border-primary-800/30 group-hover:border-primary-300 dark:group-hover:border-primary-700 transition-colors">
                    <div class="w-1.5 h-1.5 rounded-full bg-primary-600 dark:bg-primary-400 shrink-0"></div>
                    <span class="text-sm font-medium text-foreground">
                      {solution}
                    </span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="space-y-6">
        <div class="group">
          <div class="relative bg-linear-to-br from-background to-muted dark:from-background dark:to-secondary-950/50 border border-purple-300/60 dark:border-purple-800/40 rounded-3xl p-8 hover:shadow-lg transition-all duration-300 h-full overflow-hidden">
            <div class="absolute top-0 right-0 w-40 h-40 bg-purple-500/5 rounded-full blur-2xl -z-10"></div>
            <div class="relative z-10 space-y-2">
              <h3 class="text-2xl font-bold text-purple-600 dark:text-purple-400">
                {t('expertise.backend')}
              </h3>
              <p class="text-sm text-secondary-600 dark:text-secondary-400 leading-relaxed">
                {t('expertise.backendDescription')}
              </p>
            </div>
          </div>
        </div>

        <div class="group">
          <div class="relative bg-linear-to-br from-background to-muted dark:from-background dark:to-secondary-950/50 border border-blue-300/60 dark:border-blue-800/40 rounded-3xl p-8 hover:shadow-lg transition-all duration-300 h-full overflow-hidden">
            <div class="absolute top-0 right-0 w-40 h-40 bg-blue-500/5 rounded-full blur-2xl -z-10"></div>

            <div class="relative z-10 space-y-2">
              <h3 class="text-2xl font-bold text-blue-600 dark:text-blue-400">
                {t('expertise.frontend')}
              </h3>
              <p class="text-sm text-secondary-600 dark:text-secondary-400 leading-relaxed">
                {t('expertise.frontendDescription')}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>