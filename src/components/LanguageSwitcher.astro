---
import { getLangFromUrl } from '@/i18n/utils';
import { languages } from '@/config/i18n';

const currentLang = getLangFromUrl(Astro.url);
const currentPath = Astro.url.pathname;

function switchLang(path: string, targetLang: string) {
  // Remover cualquier prefijo de idioma existente
  const pathWithoutLang = path.replace(/^\/(en|es)(\/|$)/, '/');
  
  if (targetLang === 'en') {
    // Si es inglés, agregar /en al inicio
    return pathWithoutLang === '/' ? '/en' : `/en${pathWithoutLang}`;
  } else {
    // Si es español (idioma por defecto), retornar sin prefijo
    return pathWithoutLang === '/' ? '/' : pathWithoutLang;
  }
}
---

<div class="relative">
  <button
    id="langToggle"
    type="button"
    class="px-4 py-2.5 rounded-lg bg-secondary-200 dark:bg-secondary-800 hover:bg-secondary-300 dark:hover:bg-secondary-700 transition-colors font-semibold uppercase text-sm flex items-center gap-2"
  >
    <span>{currentLang}</span>
    <svg class="w-4 h-4 transition-transform" id="langIcon" fill="currentColor" viewBox="0 0 20 20">
      <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
    </svg>
  </button>
  
  <div
    id="langMenu"
    class="hidden absolute right-0 mt-3 w-40 rounded-xl shadow-2xl overflow-hidden z-50 animate-in fade-in zoom-in-95 duration-200"
  >
    <div id="langMenuContent" class="border border-secondary-100 dark:border-secondary-800 rounded-xl">
      {Object.entries(languages).map(([code, name]) => {
        const href = switchLang(currentPath, code);
        const isActive = code === currentLang;
        
        return (
          <a
            href={href}
            class={`block px-4 py-3 transition-all duration-200 border-l-4 ${
              isActive 
                ? 'border-primary-500' 
                : 'border-transparent'
            }`}
            data-lang={code}
            style={`color: inherit;`}
          >
            <span class="font-bold uppercase text-xs text-primary-600 dark:text-primary-400 block">
              {code}
            </span>
            <span class="block text-sm mt-0.5 font-medium" style="color: inherit;">
              {name}
            </span>
          </a>
        );
      })}
    </div>
  </div>
</div>

<script>
  function initLangSwitcher() {
    const toggle = document.getElementById('langToggle');
    const menu = document.getElementById('langMenu');
    const menuContent = document.getElementById('langMenuContent');
    const icon = document.getElementById('langIcon');
    
    if (!toggle || !menu || !menuContent) {
      return;
    }

    function updateMenuColors() {
      if (!menuContent) return;
      
      const isDark = document.documentElement.classList.contains('dark');
      if (isDark) {
        menuContent.style.backgroundColor = '#0f172a';
        menuContent.style.color = '#ffffff';
      } else {
        menuContent.style.backgroundColor = '#ffffff';
        menuContent.style.color = '#111827';
      }
    }
    
    updateMenuColors();
    
    const observer = new MutationObserver(updateMenuColors);
    observer.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      if (menu) {
        menu.classList.toggle('hidden');
        icon?.classList.toggle('rotate-180');
      }
    });

    document.addEventListener('click', (e) => {
      if (toggle && menu && !toggle.contains(e.target as Node) && !menu.contains(e.target as Node)) {
        menu.classList.add('hidden');
        icon?.classList.remove('rotate-180');
      }
    });
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initLangSwitcher);
  } else {
    initLangSwitcher();
  }

  document.addEventListener('astro:page-load', initLangSwitcher);
</script>