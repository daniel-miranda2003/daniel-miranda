---
import { getLangFromUrl } from '@/i18n/utils';
import { languages } from '@/config/i18n';

interface Props {
  menuAlign?: 'left' | 'right';
  compact?: boolean;
  variant?: 'dropdown' | 'inline';
}

const { menuAlign = 'right', compact = false, variant = 'dropdown' } = Astro.props;
const currentLang = getLangFromUrl(Astro.url);
const rawPath = Astro.url.pathname.replace(/\/$/, '') || '/';

function switchLang(path: string, targetLang: string) {
  const p = path.replace(/\/$/, '') || '/';
  const stripped = p.replace(/^\/(en|es)(?=\/|$)/, '');
  const rest = stripped === '' ? '/' : stripped.startsWith('/') ? stripped : `/${stripped}`;
  if (targetLang === 'en') {
    return rest === '/' ? '/en' : `/en${rest}`;
  }
  return rest;
}

const menuPosClass = menuAlign === 'left' ? 'left-0' : 'right-0';
const btnClass = compact
  ? 'w-full justify-between px-4 py-3 rounded-xl border border-border bg-secondary-200 dark:bg-secondary-800 hover:bg-secondary-300 dark:hover:bg-secondary-700 font-semibold uppercase text-sm flex items-center gap-2'
  : 'px-4 py-2.5 rounded-lg bg-secondary-200 dark:bg-secondary-800 hover:bg-secondary-300 dark:hover:bg-secondary-700 transition-colors font-semibold uppercase text-sm flex items-center gap-2';
---

{variant === 'inline' ? (
  <div class="grid grid-cols-2 gap-2" data-lang-switcher-inline>
    {Object.entries(languages).map(([code, name]) => {
      const href = switchLang(rawPath, code);
      const isActive = code === currentLang;
      return (
        <a
          href={href}
          data-astro-prefetch
          class:list={[
            'flex flex-col items-center justify-center rounded-xl border px-3 py-3 text-center transition-colors',
            isActive
              ? 'border-primary-500 bg-primary-500/10 text-foreground'
              : 'border-border bg-secondary-200 dark:bg-secondary-800 hover:bg-secondary-300 dark:hover:bg-secondary-700 text-foreground',
          ]}
        >
          <span class="font-bold uppercase text-xs text-primary-600 dark:text-primary-400">{code}</span>
          <span class="mt-1 block text-xs font-medium opacity-90">{name}</span>
        </a>
      );
    })}
  </div>
) : (
<div class="relative" data-lang-switcher>
  <button type="button" data-lang-switcher-btn class={btnClass} aria-expanded="false" aria-haspopup="true">
    <span>{currentLang}</span>
    <svg class="w-4 h-4 shrink-0 transition-transform" data-lang-switcher-icon fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
      <path fill-rule="evenodd" d="M5.293 7.293a1 1 0 011.414 0L10 10.586l3.293-3.293a1 1 0 111.414 1.414l-4 4a1 1 0 01-1.414 0l-4-4a1 1 0 010-1.414z" clip-rule="evenodd"></path>
    </svg>
  </button>

  <div
    data-lang-switcher-menu
    class:list={[
      'hidden absolute mt-2 w-40 rounded-xl shadow-2xl overflow-hidden z-[130] animate-in fade-in zoom-in-95 duration-200',
      menuPosClass,
    ]}
  >
    <div data-lang-menu-content class="border border-secondary-200 dark:border-secondary-700 rounded-xl bg-white dark:bg-slate-900">
      {Object.entries(languages).map(([code, name]) => {
        const href = switchLang(rawPath, code);
        const isActive = code === currentLang;

        return (
          <a
            href={href}
            data-astro-prefetch
            class={`block px-4 py-3 transition-all duration-200 border-l-4 ${
              isActive ? 'border-primary-500' : 'border-transparent'
            }`}
            data-lang={code}
          >
            <span class="font-bold uppercase text-xs text-primary-600 dark:text-primary-400 block">
              {code}
            </span>
            <span class="block text-sm mt-0.5 font-medium text-foreground">
              {name}
            </span>
          </a>
        );
      })}
    </div>
  </div>
</div>
)}

<script>
  let langObserver: MutationObserver | null = null;
  let langAbort: AbortController | null = null;

  function initLangSwitcher() {
    langObserver?.disconnect();
    langObserver = null;
    langAbort?.abort();
    langAbort = new AbortController();
    const signal = langAbort.signal;

    if (!document.querySelector('[data-lang-switcher]')) {
      return;
    }

    function updateOneMenuContent(root: Element) {
      const mc = root.querySelector('[data-lang-menu-content]');
      if (!mc) return;
      const isDark = document.documentElement.classList.contains('dark');
      if (isDark) {
        (mc as HTMLElement).style.backgroundColor = '#0f172a';
        (mc as HTMLElement).style.color = '#ffffff';
      } else {
        (mc as HTMLElement).style.backgroundColor = '#ffffff';
        (mc as HTMLElement).style.color = '#111827';
      }
    }

    function updateAllMenuColors() {
      document.querySelectorAll('[data-lang-switcher]').forEach(updateOneMenuContent);
    }

    document.querySelectorAll('[data-lang-switcher]').forEach((root) => {
      const toggleEl = root.querySelector<HTMLButtonElement>('[data-lang-switcher-btn]');
      const menuEl = root.querySelector<HTMLElement>('[data-lang-switcher-menu]');
      const iconEl = root.querySelector('[data-lang-switcher-icon]');
      const menuContent = root.querySelector('[data-lang-menu-content]');

      if (!toggleEl || !menuEl || !menuContent) return;

      updateOneMenuContent(root);

      toggleEl.addEventListener(
        'click',
        (e) => {
          e.stopPropagation();
          document.querySelectorAll('[data-lang-switcher-menu]').forEach((m) => {
            if (m !== menuEl) {
              m.classList.add('hidden');
              const otherRoot = m.closest('[data-lang-switcher]');
              const otherIcon = otherRoot?.querySelector('[data-lang-switcher-icon]');
              otherIcon?.classList.remove('rotate-180');
            }
          });
          menuEl.classList.toggle('hidden');
          iconEl?.classList.toggle('rotate-180');
        },
        { signal }
      );
    });

    updateAllMenuColors();
    langObserver = new MutationObserver(updateAllMenuColors);
    langObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['class'] });

    document.addEventListener(
      'click',
      (e) => {
        document.querySelectorAll('[data-lang-switcher]').forEach((root) => {
          const toggleEl = root.querySelector('[data-lang-switcher-btn]');
          const menuEl = root.querySelector('[data-lang-switcher-menu]');
          const iconEl = root.querySelector('[data-lang-switcher-icon]');
          if (!toggleEl || !menuEl) return;
          if (!toggleEl.contains(e.target as Node) && !menuEl.contains(e.target as Node)) {
            menuEl.classList.add('hidden');
            iconEl?.classList.remove('rotate-180');
          }
        });
      },
      { signal }
    );
  }

  document.addEventListener('astro:page-load', initLangSwitcher);
</script>
