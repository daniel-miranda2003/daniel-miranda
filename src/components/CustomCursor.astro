<div id="customCursor" class="custom-cursor"></div>

<style>
  .custom-cursor {
    position: fixed;
    width: 24px;
    height: 24px;
    border: 2px solid #0284c7;
    border-radius: 50%;
    pointer-events: none;
    left: 0;
    top: 0;
    transform: translate(-50%, -50%);
    z-index: 9999;
    transition: all 0.1s ease-out;
    box-shadow: 0 0 10px rgba(2, 132, 199, 0.3);
    display: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .custom-cursor {
      display: block;
    }

    body {
      cursor: none;
    }
  }

  .custom-cursor::before {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    border: 1px solid rgba(2, 132, 199, 0.2);
    border-radius: 50%;
    animation: pulse 1.5s infinite;
  }

  .custom-cursor.active {
    width: 40px;
    height: 40px;
    border-color: #E63946;
    box-shadow: 0 0 20px rgba(230, 57, 70, 0.5);
  }

  .custom-cursor.active::before {
    border-color: rgba(230, 57, 70, 0.3);
  }

  @keyframes pulse {
    0% {
      transform: scale(0.8);
      opacity: 1;
    }
    100% {
      transform: scale(1.2);
      opacity: 0;
    }
  }
</style>

<script>
  const hasMouseSupport = window.matchMedia('(hover: hover) and (pointer: fine)').matches;

  if (hasMouseSupport) {
    const cursor = document.getElementById('customCursor');
    let mouseX = 0;
    let mouseY = 0;

    document.addEventListener('mousemove', (e) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      if (cursor) {
        cursor.style.left = mouseX + 'px';
        cursor.style.top = mouseY + 'px';
      }
    });

    const interactiveElements = document.querySelectorAll('a, button, input, [role="button"]');

    interactiveElements.forEach((el) => {
      el.addEventListener('mouseenter', () => {
        cursor?.classList.add('active');
      });

      el.addEventListener('mouseleave', () => {
        cursor?.classList.remove('active');
      });
    });

    document.addEventListener('mouseleave', () => {
      if (cursor) cursor.style.opacity = '0';
    });

    document.addEventListener('mouseenter', () => {
      if (cursor) cursor.style.opacity = '1';
    });
  }
</script>