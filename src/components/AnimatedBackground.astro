---
---

<div id="animatedBg" class="animated-background">
  <canvas id="particleCanvas"></canvas>
  <div class="bg-gradient bg-gradient--base"></div>
  <div class="bg-gradient bg-gradient--sky" aria-hidden="true"></div>
  <div class="bg-mesh" aria-hidden="true"></div>
</div>

<style>
  .animated-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: -1;
    pointer-events: none;
  }

  #particleCanvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .bg-gradient {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  .bg-gradient--base {
    background: linear-gradient(
      125deg,
      rgba(255, 255, 255, 0.82) 0%,
      rgba(224, 242, 254, 0.45) 42%,
      rgba(255, 255, 255, 0.78) 100%
    );
    animation: gradientShift 18s ease-in-out infinite;
  }

  :global(.dark) .bg-gradient--base {
    background: linear-gradient(
      125deg,
      rgba(15, 23, 42, 0.58) 0%,
      rgba(30, 41, 59, 0.52) 45%,
      rgba(15, 23, 42, 0.58) 100%
    );
  }

  .bg-gradient--sky {
    mix-blend-mode: multiply;
    opacity: 0.45;
    background: linear-gradient(
      210deg,
      rgba(56, 189, 248, 0.1) 0%,
      transparent 40%,
      rgba(14, 165, 233, 0.08) 70%,
      rgba(125, 211, 252, 0.06) 100%
    );
    background-size: 200% 200%;
    animation: gradientDrift 22s ease-in-out infinite;
  }

  :global(.dark) .bg-gradient--sky {
    mix-blend-mode: normal;
    opacity: 0.18;
    background: linear-gradient(
      210deg,
      rgba(56, 189, 248, 0.1) 0%,
      transparent 45%,
      rgba(14, 165, 233, 0.08) 100%
    );
    background-size: 200% 200%;
  }

  .bg-mesh {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 20% -10%, rgba(14, 165, 233, 0.12), transparent 50%),
      radial-gradient(ellipse 70% 45% at 100% 30%, rgba(2, 132, 199, 0.1), transparent 45%),
      radial-gradient(ellipse 60% 40% at 50% 100%, rgba(125, 211, 252, 0.08), transparent 40%);
    animation: meshPulse 28s ease-in-out infinite;
    pointer-events: none;
  }

  :global(.dark) .bg-mesh {
    background:
      radial-gradient(ellipse 80% 50% at 15% 0%, rgba(56, 189, 248, 0.06), transparent 50%),
      radial-gradient(ellipse 70% 45% at 95% 25%, rgba(14, 165, 233, 0.05), transparent 45%),
      radial-gradient(ellipse 55% 35% at 55% 95%, rgba(125, 211, 252, 0.04), transparent 42%);
  }

  @keyframes gradientShift {
    0%,
    100% {
      opacity: 0.92;
    }
    50% {
      opacity: 1;
    }
  }

  @keyframes gradientDrift {
    0%,
    100% {
      background-position: 0% 30%;
    }
    50% {
      background-position: 100% 70%;
    }
  }

  @keyframes meshPulse {
    0%,
    100% {
      opacity: 0.88;
      transform: scale(1);
    }
    50% {
      opacity: 1;
      transform: scale(1.01);
    }
  }
</style>

<script>
  interface Particle {
    x: number;
    y: number;
    size: number;
    speedX: number;
    speedY: number;
    opacity: number;
    color: string;
  }

  const canvas = document.getElementById('particleCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d');
  if (!ctx) throw new Error('Canvas context not found');

  let particles: Particle[] = [];
  const particleCount = 42;

  const resizeCanvas = () => {
    const dpr = window.devicePixelRatio || 1;
    const rect = canvas.getBoundingClientRect();
    canvas.width = Math.max(1, Math.floor(rect.width * dpr));
    canvas.height = Math.max(1, Math.floor(rect.height * dpr));
    ctx.setTransform(1, 0, 0, 1, 0, 0);
    ctx.scale(dpr, dpr);
    canvas.style.width = rect.width + 'px';
    canvas.style.height = rect.height + 'px';
    createParticles();
  };

  const getColors = () => {
    const isDark = document.documentElement.classList.contains('dark');
    return {
      primary: isDark ? 'rgba(56, 189, 248, 0.85)' : 'rgba(2, 132, 199, 0.55)',
      secondary: isDark ? 'rgba(125, 211, 252, 0.65)' : 'rgba(230, 57, 70, 0.45)',
      accent: isDark ? 'rgba(14, 165, 233, 0.75)' : 'rgba(14, 165, 233, 0.45)',
    };
  };

  const createParticles = () => {
    const rect = canvas.getBoundingClientRect();
    particles = [];
    const colors = getColors();
    const colorArray = [colors.primary, colors.secondary, colors.accent];
    const isDark = document.documentElement.classList.contains('dark');

    for (let i = 0; i < particleCount; i++) {
      particles.push({
        x: Math.random() * rect.width,
        y: Math.random() * rect.height,
        size: isDark ? Math.random() * 2.8 + 1.5 : Math.random() * 3 + 1.8,
        speedX: (Math.random() - 0.5) * 0.45,
        speedY: (Math.random() - 0.5) * 0.45,
        opacity: isDark ? Math.random() * 0.35 + 0.38 : Math.random() * 0.45 + 0.25,
        color: colorArray[Math.floor(Math.random() * colorArray.length)],
      });
    }
  };

  const drawParticles = () => {
    const colors = getColors();
    const rect = canvas.getBoundingClientRect();
    const isDark = document.documentElement.classList.contains('dark');
    const linkDist = isDark ? 125 : 140;
    const linkAlphaMul = isDark ? 0.14 : 0.22;

    particles.forEach((particle, index) => {
      particle.x += particle.speedX;
      particle.y += particle.speedY;

      if (particle.x < 0 || particle.x > rect.width) particle.speedX *= -1;
      if (particle.y < 0 || particle.y > rect.height) particle.speedY *= -1;

      particle.x = Math.max(0, Math.min(rect.width, particle.x));
      particle.y = Math.max(0, Math.min(rect.height, particle.y));

      ctx.fillStyle = particle.color;
      ctx.globalAlpha = particle.opacity;
      ctx.beginPath();
      ctx.arc(particle.x, particle.y, particle.size, 0, Math.PI * 2);
      ctx.fill();

      particles.forEach((otherParticle, otherIndex) => {
        if (index < otherIndex) {
          const dx = particle.x - otherParticle.x;
          const dy = particle.y - otherParticle.y;
          const distance = Math.sqrt(dx * dx + dy * dy);
          if (distance < linkDist) {
            ctx.strokeStyle = colors.primary;
            ctx.globalAlpha = (1 - distance / linkDist) * linkAlphaMul;
            ctx.lineWidth = isDark ? 0.55 : 0.7;
            ctx.beginPath();
            ctx.moveTo(particle.x, particle.y);
            ctx.lineTo(otherParticle.x, otherParticle.y);
            ctx.stroke();
          }
        }
      });
    });

    ctx.globalAlpha = 1;
  };

  const animate = () => {
    const rect = canvas.getBoundingClientRect();
    const w = rect.width;
    const h = rect.height;
    const isDark = document.documentElement.classList.contains('dark');
    ctx.fillStyle = isDark ? 'rgb(15, 23, 42)' : 'rgb(255, 255, 255)';
    ctx.globalAlpha = 1;
    ctx.fillRect(0, 0, w, h);

    drawParticles();
    requestAnimationFrame(animate);
  };

  resizeCanvas();
  animate();

  window.addEventListener('resize', resizeCanvas);

  const observer = new MutationObserver(() => {
    createParticles();
  });
  observer.observe(document.documentElement, {
    attributes: true,
    attributeFilter: ['class'],
  });
</script>
