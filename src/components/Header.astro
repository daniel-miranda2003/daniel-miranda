---
import ThemeToggle from '@/components/ThemeToggle.astro';
import LanguageSwitcher from '@/components/LanguageSwitcher.astro';
import { useTranslations, getCVPath } from '@/i18n/utils';
import { getLangFromUrl } from '@/i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const cvPath = getCVPath(lang);
---

<header id="header" class="fixed top-0 left-0 right-0 z-[100]">
  <div
    id="mobile-backdrop"
    class="mobile-backdrop fixed inset-0 z-[100] bg-slate-900/60 dark:bg-black/75 md:hidden opacity-0 pointer-events-none transition-opacity duration-200"
    aria-hidden="true"
  ></div>
  <div
    id="mobile-drawer"
    class="mobile-drawer fixed inset-y-0 left-0 z-[105] flex w-[min(300px,88vw)] max-w-[320px] -translate-x-full flex-col border-r border-slate-200 bg-white pt-14 shadow-2xl transition-transform duration-200 ease-out dark:border-slate-700 dark:bg-slate-950 md:hidden overscroll-contain"
    style="isolation: isolate;"
    role="dialog"
    aria-modal="true"
    aria-label={lang === 'es' ? 'Navegación' : 'Navigation'}
  >
    <div class="mobile-drawer-scroll flex min-h-0 flex-1 flex-col overflow-y-auto bg-white dark:bg-slate-950">
      <ul class="flex flex-col gap-1 px-4 py-5">
      <li><a href="#inicio" class="nav-link-mobile block rounded-lg px-3 py-3 text-foreground font-medium hover:bg-muted">{t('nav.home')}</a></li>
      <li><a href="#experiencia" class="nav-link-mobile block rounded-lg px-3 py-3 text-foreground font-medium hover:bg-muted">{t('nav.expertise')}</a></li>
      <li><a href="#sobre-mi" class="nav-link-mobile block rounded-lg px-3 py-3 text-foreground font-medium hover:bg-muted">{t('nav.about')}</a></li>
      <li><a href="#habilidades" class="nav-link-mobile block rounded-lg px-3 py-3 text-foreground font-medium hover:bg-muted">{t('nav.skills')}</a></li>
      <li><a href="#proyectos" class="nav-link-mobile block rounded-lg px-3 py-3 text-foreground font-medium hover:bg-muted">{t('nav.projects')}</a></li>
      <li><a href="#contacto" class="nav-link-mobile block rounded-lg px-3 py-3 text-foreground font-medium hover:bg-muted">{t('nav.contact')}</a></li>
      <li class="pt-2 mt-2 border-t border-border">
        <a
          href={cvPath}
          target="_blank"
          rel="noopener noreferrer"
          class="nav-link-mobile flex items-center gap-2 rounded-lg px-3 py-3 font-semibold bg-muted text-foreground hover:bg-muted/80"
        >
          <svg class="w-5 h-5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
          </svg>
          {t('nav.cv')}
        </a>
      </li>
      <li class="pt-5 mt-4 border-t border-border">
        <p class="mb-3 px-3 text-xs font-semibold uppercase tracking-wide text-muted-foreground">
          {t('nav.drawerPrefs')}
        </p>
        <div class="flex flex-col gap-4 px-3">
          <div class="flex items-center gap-4">
            <span class="min-w-0 flex-1 text-sm font-medium text-foreground">{t('theme.toggle')}</span>
            <ThemeToggle ariaLabel={t('theme.toggle')} />
          </div>
          <div class="space-y-2">
            <span class="text-xs font-semibold uppercase tracking-wide text-muted-foreground">{t('lang.select')}</span>
            <LanguageSwitcher variant="inline" />
          </div>
        </div>
      </li>
    </ul>
    </div>
  </div>
  <div
    id="header-bar"
    class="relative z-[120] w-full bg-background/95 backdrop-blur-sm transition-transform duration-300 ease-out will-change-transform md:bg-background md:backdrop-blur-none md:shadow-sm"
  >
    <nav class="relative flex w-full max-w-6xl mx-auto items-center justify-between px-4 py-3 min-h-[3.5rem] border-b border-border/70 bg-transparent shadow-none md:border-b-0 md:shadow-none">
      <button
        type="button"
        id="mobile-menu-btn"
        class="md:hidden inline-flex h-11 w-11 items-center justify-center rounded-xl border border-border bg-background text-foreground shadow-sm transition-colors hover:bg-muted/80 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 focus-visible:ring-offset-background"
        aria-expanded="false"
        aria-controls="mobile-drawer"
        aria-label="Menu"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
      <div class="hidden md:block w-10 shrink-0" aria-hidden="true"></div>
      <ul class="hidden md:flex absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 items-center gap-5 lg:gap-6">
        <li><a href="#inicio" class="nav-link text-foreground/80 hover:text-foreground transition-colors whitespace-nowrap">{t('nav.home')}</a></li>
        <li><a href="#experiencia" class="nav-link text-foreground/80 hover:text-foreground transition-colors whitespace-nowrap">{t('nav.expertise')}</a></li>
        <li><a href="#sobre-mi" class="nav-link text-foreground/80 hover:text-foreground transition-colors whitespace-nowrap">{t('nav.about')}</a></li>
        <li><a href="#habilidades" class="nav-link text-foreground/80 hover:text-foreground transition-colors whitespace-nowrap">{t('nav.skills')}</a></li>
        <li><a href="#proyectos" class="nav-link text-foreground/80 hover:text-foreground transition-colors whitespace-nowrap">{t('nav.projects')}</a></li>
        <li><a href="#contacto" class="nav-link text-foreground/80 hover:text-foreground transition-colors whitespace-nowrap">{t('nav.contact')}</a></li>
      </ul>
      <div class="hidden md:flex items-center gap-2 sm:gap-3 shrink-0">
        <div class="relative group">
          <a
            href={cvPath}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center justify-center p-2.5 rounded-lg bg-secondary-200 dark:bg-secondary-800 hover:bg-secondary-300 dark:hover:bg-secondary-700 transition-all duration-200"
            aria-label={t('nav.cv')}
          >
            <svg class="w-5 h-5 text-foreground" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </a>
          <span class="absolute right-0 top-full mt-2 px-3 py-1.5 bg-gray-900 dark:bg-gray-100 text-white dark:text-gray-900 text-sm rounded-lg opacity-0 group-hover:opacity-100 transition-opacity duration-200 whitespace-nowrap pointer-events-none">
            {t('nav.cv')}
          </span>
        </div>
        <ThemeToggle ariaLabel={t('theme.toggle')} />
        <LanguageSwitcher />
      </div>
    </nav>
  </div>
</header>

<script>
  let headerAbort: AbortController | null = null;
  let scrollIdleTimer: ReturnType<typeof setTimeout> | null = null;
  let lastScrollY = 0;

  function setMenuOpen(open: boolean) {
    const backdrop = document.getElementById('mobile-backdrop');
    const drawer = document.getElementById('mobile-drawer');
    const btn = document.getElementById('mobile-menu-btn');
    if (!backdrop || !drawer || !btn) return;
    if (open) {
      backdrop.classList.remove('opacity-0', 'pointer-events-none');
      backdrop.classList.add('opacity-100');
      drawer.classList.remove('-translate-x-full');
      btn.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    } else {
      backdrop.classList.add('opacity-0', 'pointer-events-none');
      backdrop.classList.remove('opacity-100');
      drawer.classList.add('-translate-x-full');
      btn.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
  }

  function initHeader() {
    headerAbort?.abort();
    headerAbort = new AbortController();
    const signal = headerAbort.signal;

    const header = document.getElementById('header-bar');
    const mobileMenuBtn = document.getElementById('mobile-menu-btn');
    const backdrop = document.getElementById('mobile-backdrop');
    const drawer = document.getElementById('mobile-drawer');

    if (!header || !mobileMenuBtn) return;

    lastScrollY = window.scrollY;

    function showHeaderBar() {
      header?.classList.remove('-translate-y-full');
    }

    function hideHeaderBar() {
      if (drawer && !drawer.classList.contains('-translate-x-full')) return;
      header?.classList.add('-translate-y-full');
    }

    function scheduleShowAfterIdle() {
      if (scrollIdleTimer) clearTimeout(scrollIdleTimer);
      scrollIdleTimer = setTimeout(() => {
        showHeaderBar();
        scrollIdleTimer = null;
      }, 850);
    }

    window.addEventListener(
      'scroll',
      () => {
        const y = window.scrollY;
        if (scrollIdleTimer) {
          clearTimeout(scrollIdleTimer);
          scrollIdleTimer = null;
        }

        if (y < 32) {
          showHeaderBar();
          lastScrollY = y;
          return;
        }

        if (y > lastScrollY + 6) {
          hideHeaderBar();
          scheduleShowAfterIdle();
        } else if (y < lastScrollY - 6) {
          showHeaderBar();
        }

        lastScrollY = y;
      },
      { passive: true, signal }
    );

    mobileMenuBtn.addEventListener(
      'click',
      () => {
        const open = drawer?.classList.contains('-translate-x-full');
        setMenuOpen(!!open);
      },
      { signal }
    );

    backdrop?.addEventListener(
      'click',
      () => {
        setMenuOpen(false);
      },
      { signal }
    );

    document.querySelectorAll('.nav-link-mobile').forEach((link) => {
      link.addEventListener(
        'click',
        (e) => {
          const href = link.getAttribute('href');
          const isHashLink = href?.startsWith('#');

          setMenuOpen(false);

          if (!isHashLink) {
            return;
          }

          e.preventDefault();
          const targetId = href.substring(1);
          const target = document.getElementById(targetId);
          if (target) {
            const headerOffset = 88;
            const top = target.getBoundingClientRect().top + window.pageYOffset - headerOffset;
            window.scrollTo({ top, behavior: 'smooth' });
          }
        },
        { signal }
      );
    });

    document.querySelectorAll('.nav-link').forEach((link) => {
      link.addEventListener(
        'click',
        (e) => {
          e.preventDefault();
          const href = link.getAttribute('href')?.substring(1);
          const target = document.getElementById(href || '');
          if (target) {
            const headerOffset = 88;
            const top = target.getBoundingClientRect().top + window.pageYOffset - headerOffset;
            window.scrollTo({ top, behavior: 'smooth' });
          }
        },
        { signal }
      );
    });
  }

  document.addEventListener('astro:page-load', initHeader);
</script>

<style>
  .nav-link {
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: rgb(var(--color-primary-600));
    transition: width 0.3s ease;
  }

  .nav-link:hover::after {
    width: 100%;
  }
</style>

<style is:global>
  #mobile-drawer.mobile-drawer,
  #mobile-drawer .mobile-drawer-scroll {
    background-color: #ffffff !important;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
  }
  html.dark #mobile-drawer.mobile-drawer,
  html.dark #mobile-drawer .mobile-drawer-scroll {
    background-color: #020617 !important;
  }
</style>
